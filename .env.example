# DVP Portal Backend - Environment Configuration Template
# Copy this file to .env and fill in your values

# Project
PROJECT_NAME="Digital Verification Portal (DVP) API"

# API
API_V1_STR=/api/v1

# Security
SECRET_KEY=your-secure-random-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dvp
# DATABASE_URL=postgresql+psycopg://user:pass@host:port/dbname

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=dvp

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
UPLOAD_DIR=uploads

# OTP and Token limits
OTP_EXPIRE_MINUTES=5
OTP_ATTEMPT_LIMIT=3
RESET_TOKEN_EXPIRE_MINUTES=15

# Mail
MAIL_FROM=noreply@dvp-portal.com
MAIL_SENDER=DVP System
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
EMAIL_QUEUE_RETRY_LIMIT=3

# Subscription defaults
DEFAULT_TRIAL_DAYS=14
DEFAULT_BILLING_CYCLE_DAYS=30
DEFAULT_EXPIRY_REMINDER_DAYS=7
MONTHLY_QUOTA_RESET_DAY=1

# Initial superadmin bootstrap
SUPERADMIN_EMAIL=your-superadmin-email@example.com
SUPERADMIN_PASSWORD=change-this-password-before-first-login