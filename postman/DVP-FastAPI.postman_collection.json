          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.access_token) pm.environment.set('access_token', data.access_token);",
                  "  if (data.refresh_token) pm.environment.set('refresh_token', data.refresh_token);",
                  "  if (typeof data.must_change_password !== 'undefined') pm.environment.set('must_change_password', String(data.must_change_password));",
